# ============================================
# MamaCare — Environment Variables
# Copy to .env.local for local dev. Paste each into Vercel → Settings → Environment Variables.
# ============================================

# ---------- Site ----------
NEXT_PUBLIC_SITE_URL=https://mama-care-store.vercel.app

# ---------- Admin accounts (two named admins) ----------
# Each admin has user/password + a display NAME used for activity logging.
ADMIN_USER_1=david
ADMIN_PASSWORD_1=change-me-strong
ADMIN_NAME_1=David

ADMIN_USER_2=coadmin
ADMIN_PASSWORD_2=change-me-strong-too
ADMIN_NAME_2=Co-admin

# Used only to gate the one-time DB init endpoint:
ADMIN_SECRET=long-random-string-for-init-endpoint

# (Legacy single-admin fallback — only used if ADMIN_USER_1 is not set)
# ADMIN_USER=
# ADMIN_PASSWORD=

# ---------- Stripe ----------
STRIPE_SECRET_KEY=rk_live_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ---------- PayPal ----------
NEXT_PUBLIC_PAYPAL_CLIENT_ID=replace_me
PAYPAL_CLIENT_SECRET=replace_me
PAYPAL_ENV=live

# ---------- CJ Dropshipping ----------
CJ_API_EMAIL=you@example.com
CJ_API_KEY=replace_me
CJ_API_BASE=https://developers.cjdropshipping.com/api2.0/v1

# ---------- Resend (transactional + receipt emails) ----------
RESEND_API_KEY=re_replace_me
RESEND_FROM=MamaCare <orders@yourdomain.com>
CONTACT_EMAIL=mamaacaree@gmail.com

# ---------- Vercel Postgres ----------
# Auto-injected when you connect a Postgres database to the project.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ---------- Analytics (optional) ----------
NEXT_PUBLIC_GA_ID=
