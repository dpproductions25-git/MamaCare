# ============================================
# MamaCare — Environment Variables
# Copy this file to .env.local for local dev,
# and paste each variable into Vercel → Project → Settings → Environment Variables.
# ============================================

# ---------- Site ----------
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ---------- Admin dashboard (HTTP Basic Auth on /admin/*) ----------
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-to-something-strong
# Used only to gate the one-time DB init endpoint:
ADMIN_SECRET=another-long-random-string

# ---------- Stripe ----------
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
# https://dashboard.stripe.com/webhooks → after creating endpoint
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ---------- PayPal ----------
# https://developer.paypal.com/dashboard/applications
NEXT_PUBLIC_PAYPAL_CLIENT_ID=replace_me
PAYPAL_CLIENT_SECRET=replace_me
PAYPAL_ENV=sandbox       # sandbox | live

# ---------- CJ Dropshipping ----------
# https://app.cjdropshipping.com/   →  My CJ → Authorization Management → API
CJ_API_EMAIL=you@example.com
CJ_API_KEY=replace_me
CJ_API_BASE=https://developers.cjdropshipping.com/api2.0/v1

# ---------- Resend (transactional email) ----------
# https://resend.com/api-keys
RESEND_API_KEY=re_replace_me
# Must be a verified sender on Resend
RESEND_FROM=MamaCare <orders@yourdomain.com>
CONTACT_EMAIL=hello@yourdomain.com

# ---------- Vercel Postgres ----------
# These are auto-injected by Vercel when you create a Postgres database
# and connect it to the project. No manual setup required in production.
# For local dev, copy them from Vercel → Storage → your DB → .env.local tab.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ---------- Analytics (optional) ----------
NEXT_PUBLIC_GA_ID=
